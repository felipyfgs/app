# Copie para .env.prod, proteja com chmod 600 e nunca versione o arquivo real.
# Backup cifrado: use docker/ops/backup.env.example → /etc/fiscal-hub/backup.env
# (BACKUP_PACKAGE_KEY NÃO fica aqui nem nos containers da app).
APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.inovaicontabil.com.br
APP_KEY=base64:substitua-por-php-artisan-key-generate
VAULT_MASTER_KEY=substitua-por-32-bytes-aleatorios-em-base64
VAULT_MASTER_KEY_VERSION=1
# Após rotação: manter versões anteriores só na janela de rewrap (nunca versionar valores reais)
VAULT_PREVIOUS_MASTER_KEYS=

# Release (preenchida pelo deploy; opcional no arquivo se exportada no shell)
# RELEASE_SHA=
# RELEASE_TAG=

AUTH_TWO_FACTOR_REQUIRED=true
SESSION_DOMAIN=app.inovaicontabil.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=app.inovaicontabil.com.br

DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=substitua-por-uma-senha-forte

ACME_EMAIL=infra@example.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=substitua-pelo-usuario-smtp
MAIL_PASSWORD=substitua-pela-senha-smtp
MAIL_FROM_ADDRESS=noreply@app.inovaicontabil.com.br
MAIL_FROM_NAME="Inovai Contábil"

# Onboarding inicial — só base vazia; desligar após o primeiro PLATFORM_ADMIN.
INITIAL_ONBOARDING_ENABLED=false
INITIAL_ONBOARDING_TOKEN=

# Os canais fiscais e mutações permanecem desligados até habilitação formal.
FEATURES_KILL_SWITCH=false
FEATURES_GLOBAL_ENABLED=false
FEATURES_MUTATING_ENABLED=false
FEATURES_MUTATING_KILL_SWITCH=false
# Contexto privilegiado PLATFORM_ADMIN — OFF até gate jurídico/segurança.
PLATFORM_PRIVILEGED_CONTEXT=false

# SERPRO / Integra Contador — contenção go-live (defaults fail-closed)
SERPRO_DEFAULT_ENVIRONMENT=PRODUCTION
SERPRO_USE_FAKE_CLIENTS=false
SERPRO_KILL_SWITCH=true
SERPRO_CAPABILITY_DEFAULT=disabled
SERPRO_CAPABILITY_SITFIS=disabled
SERPRO_CAPABILITY_AUTENTICA_PROCURADOR=disabled
SERPRO_CAPABILITY_AUTHORIZATION=disabled
SERPRO_CAPABILITY_MAILBOX=disabled
SERPRO_CAPABILITY_DCTFWEB=disabled
SERPRO_CAPABILITY_SIMPLES_MEI=disabled
SERPRO_CAPABILITY_INSTALLMENTS=disabled
SERPRO_CAPABILITY_GUIDES=disabled
SERPRO_CAPABILITY_REGISTRATIONS=disabled
SERPRO_CAPABILITY_TAX_PROCESSES=disabled
SERPRO_USAGE_SHADOW_MODE=true
SERPRO_USAGE_COMMERCIAL_BLOCKING=false
SERPRO_SMOKE_ENABLED=false
SERPRO_PROD_CHECK_STRICT=true
# Flags reais permanecem OFF até promoção explícita + quatro olhos
SERPRO_RETENTION_PFX_DAYS=2555
SERPRO_RETENTION_TOKEN_DAYS=0
SERPRO_RETENTION_TERMO_DAYS=2555
SERPRO_RETENTION_LEDGER_DAYS=2555
SERPRO_CREDENTIAL_CUTOVER_APPROVALS=2

# SEFAZ / autXML — OFF no primeiro go-live da plataforma
SEFAZ_DISTDFE_ENABLED=false
SEFAZ_MANIFEST_ENABLED=false
SEFAZ_CTE_ENABLED=false
SEFAZ_NFCE_ENABLED=false
SEFAZ_MA_OUTBOUND_ENABLED=false
SEFAZ_AUTXML_DISTDFE_ENABLED=false
SEFAZ_CTE_AUTXML_DISTDFE_ENABLED=false
SEFAZ_SVRS_NFCE_XML_RETRIEVAL_ENABLED=false
SEFAZ_SVRS_NFE55_XML_RETRIEVAL_ENABLED=false

# Heartbeat do scheduler (segundos)
OPS_SCHEDULER_HEARTBEAT_MAX_AGE=180

