APP_NAME="NFS-e ADN"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Manter true fora do desenvolvimento local.
AUTH_TWO_FACTOR_REQUIRED=true

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Vazio para cookie no host do browser (IP remoto). Evite a string "null".
SESSION_DOMAIN=
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum (same-origin SPA)
# Inclua host:porta usados no browser (ex.: IP:3000 em acesso remoto).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,localhost:3000,127.0.0.1,127.0.0.1:8080,127.0.0.1:3000

# Cofre de objetos (chave mestra fora do banco e de backups comuns)
VAULT_MASTER_KEY=
VAULT_MASTER_KEY_VERSION=1
VAULT_DISK_ROOT=/var/vault

# Backup da instância (metadados em instance_backup_runs; artefatos fora do webroot)
BACKUP_DISK_ROOT=/var/backups/nfse
BACKUP_RETENTION_RUNS=7
BACKUP_RETENTION_FAILED_RUNS=2
BACKUP_SCHEDULE_ENABLED=false

# ADN
ADN_BASE_URL=https://adn.nfse.gov.br/contribuintes
ADN_ENVIRONMENT=restricted_production
ADN_TIMEOUT_SECONDS=30
ADN_CONNECT_TIMEOUT_SECONDS=10
ADN_MAX_CONCURRENT=4
ADN_RATE_LIMIT_RPS=4
ADN_MAX_PAGES_PER_JOB=20
ADN_DECODE_FAILURE_THRESHOLD=5
ADN_JOB_TIMEOUT_SECONDS=900
ADN_LOCK_TTL_SECONDS=960
ADN_STALE_LEASE_SECONDS=1020

# Consulta pública opcional para auxiliar o cadastro (o cadastro manual permanece disponível)
CNPJ_PUBLIC_LOOKUP_URL=https://publica.cnpj.ws/cnpj
CNPJ_PUBLIC_LOOKUP_TIMEOUT_SECONDS=5
CNPJ_PUBLIC_LOOKUP_CACHE_SECONDS=86400

# Horizon
HORIZON_PREFIX=nfse_horizon:
HORIZON_JOB_TIMEOUT=900
REDIS_QUEUE_RETRY_AFTER=960

# Captura de saídas MA (NF-e 55 / NFC-e 65) — default off (G0)
# Ver docs/ops/ma-outbound-g0-decision.md
SEFAZ_MA_OUTBOUND_ENABLED=false
SEFAZ_MA_PROTOCOL_QUERY_ENABLED=false
SEFAZ_MA_M2M_RETRIEVAL_ENABLED=false
SEFAZ_MA_MUTATING_PROBE_ENABLED=false
SEFAZ_MA_OUTBOUND_KILL_SWITCH=false
SEFAZ_MA_M2M_STATUS=NO_GO_M2M
SEFAZ_MA_OUTBOUND_QUEUE=capture-outbound-ma
SEFAZ_MA_OUTBOUND_RPS=1
SEFAZ_MA_OUTBOUND_MAX_NUMBERS_PER_RUN=10
SEFAZ_MA_OUTBOUND_RETRY_HOURS=12
SEFAZ_MA_OUTBOUND_MAX_ATTEMPTS=10
SEFAZ_MA_OUTBOUND_SEED_MAX_AGE_DAYS=60

# Canal SVRS — download nfeProc NFC-e 65 por chave + A1 (default off)
# Ver docs/ops/svrs-nfce-enablement-matrix.md
SEFAZ_SVRS_NFCE_XML_RETRIEVAL_ENABLED=false
SEFAZ_SVRS_NFCE_XML_AUTO_QUEUE_ENABLED=false
SEFAZ_SVRS_NFCE_XML_PILOT_ALLOWLIST_ONLY=false
SEFAZ_SVRS_NFCE_XML_KILL_SWITCH=false
SEFAZ_SVRS_NFCE_XML_HOST=dfe-portal.svrs.rs.gov.br
SEFAZ_SVRS_NFCE_XML_QUEUE=capture-outbound-ma
SEFAZ_SVRS_NFCE_XML_TIMEOUT_SECONDS=30
SEFAZ_SVRS_NFCE_XML_MAX_KEYS_PER_RUN=20
SEFAZ_SVRS_NFCE_XML_PARSER_VERSION=1

# Canal autXML DistDFe do escritório (default off — gates de piloto)
# Ver docs/ops/autxml-external-distnsu-consumers.md
SEFAZ_AUTXML_DISTDFE_ENABLED=false
SEFAZ_AUTXML_KILL_SWITCH=false
SEFAZ_AUTXML_OFFICE_ALLOWLIST=
SEFAZ_AUTXML_ALLOW_ALL_OFFICES=false
SEFAZ_AUTXML_QUEUE=sync-sefaz-autxml
SEFAZ_AUTXML_MAX_PAGES_PER_JOB=20

# Import em massa XML/ZIP (limites; batch assíncrono default off)
IMPORT_ASYNC_BATCHES_ENABLED=false
IMPORT_MAX_TOP_LEVEL_FILES=50
IMPORT_MAX_FILE_KIB=20480
IMPORT_MAX_REQUEST_COMPRESSED_BYTES=20971520
IMPORT_MAX_XML_ENTRIES=5000
IMPORT_MAX_XML_BYTES=5242880
IMPORT_MAX_BATCH_UNCOMPRESSED_BYTES=262144000
IMPORT_MAX_COMPRESSION_RATIO=100

