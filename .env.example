# Copie para .env, proteja com chmod 600 e nunca versione o arquivo real.
# O mesmo arquivo .env é usado para dev ou produção; ajuste APP_ENV e flags conforme o alvo.
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
COMPOSE_PROJECT_NAME=app
APP_PORT=8080
FRONTEND_DEV_PORT=3000
# IP ou hostname usado no browser remoto (HMR WebSocket do Nuxt dev)
# PUBLIC_HOST=192.168.0.10
CHOKIDAR_USEPOLLING=true

# Produção: obrigatório para HTTPS e cookies seguros.
ACME_EMAIL=infra@example.com
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:3000
AUTH_TWO_FACTOR_REQUIRED=false

# PostgreSQL
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=change-me
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend/prod secrets (também em apps/api/.env no dev — ver apps/api/.env.example)
APP_KEY=base64:substitua-por-php-artisan-key-generate
VAULT_MASTER_KEY=substitua-por-32-bytes-aleatorios-em-base64
VAULT_MASTER_KEY_VERSION=1
VAULT_PREVIOUS_MASTER_KEYS=
# BACKUP_DISK_ROOT=/var/backups/nfse
# BACKUP_RETENTION_RUNS=7
# BACKUP_SCHEDULE_ENABLED=false

# E-mail e logs
LOG_CHANNEL=stderr
LOG_LEVEL=debug
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=substitua-pelo-usuario-smtp
MAIL_PASSWORD=substitua-pela-senha-smtp
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Fiscal Hub"

# Onboarding inicial — desligar após o primeiro PLATFORM_ADMIN.
INITIAL_ONBOARDING_ENABLED=false
INITIAL_ONBOARDING_TOKEN=

# Perfil único do núcleo fiscal: dev | trial | production.
# Compose injeta FISCAL_PROFILE nos containers PHP (sobrescreve apps/api/.env se omitido aqui).
# production = drivers reais + bilhetagem SERPRO — só para avaliação local deliberada.
FISCAL_PROFILE=dev
FISCAL_KILL_SWITCH=false
PLATFORM_PRIVILEGED_CONTEXT=false

# SERPRO / Integra Contador — defaults fail-closed. Nunca coloque Consumer Secret/PFX aqui.
SERPRO_DEFAULT_ENVIRONMENT=TRIAL
SERPRO_USE_FAKE_CLIENTS=false
SERPRO_KILL_SWITCH=true

# Automacao interna dos portais MEI
MEI_AUTOMATION_ENABLED=false
MEI_AUTOMATION_LIVE_EGRESS_ENABLED=false
MEI_AUTOMATION_FIXTURE_ENABLED=false
MEI_AUTOMATION_HMAC_KEY_ID=laravel
MEI_AUTOMATION_HMAC_SECRET=
MEI_AUTOMATION_POLL_INTERVAL=10
MEI_AUTOMATION_RESULT_TTL_SECONDS=900
MEI_AUTOMATION_ARTIFACT_MAX_BYTES=10485760
MEI_AUTOMATION_ARTIFACT_TTL_SECONDS=300
MEI_AUTOMATION_REDIS_URL=redis://redis:6379/4
MEI_AUTOMATION_PROVIDER_DEFAULT=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DAS_PDF=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DAS_BARCODE=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DEBT=serpro
MEI_AUTOMATION_PROVIDER_DASN_HISTORY=serpro
MEI_AUTOMATION_CAPTCHA_DRIVER=manual
MEI_AUTOMATION_CAPTCHA_BUDGET_MICROS=0
MEI_AUTOMATION_NOPECHA_ENABLED=false
MEI_AUTOMATION_NOPECHA_API_KEY=
MEI_AUTOMATION_NOPECHA_OPERATION_ALLOWLIST=
MEI_AUTOMATION_NOPECHA_UNIT_COST_MICROS=0
MEI_AUTOMATION_NOPECHA_TIMEOUT_SECONDS=180
MEI_AUTOMATION_NOPECHA_POLL_INTERVAL_SECONDS=1
# Opcional: http://user:pass@host:port (IP do proxy deve ser o do submit)
MEI_AUTOMATION_NOPECHA_PROXY_URL=
MEI_AUTOMATION_BROWSER_HEADLESS=false
MEI_AUTOMATION_BROWSER_CHANNEL=chrome
SERPRO_USAGE_SHADOW_MODE=true
SERPRO_USAGE_COMMERCIAL_BLOCKING=false
SERPRO_SMOKE_ENABLED=false
SERPRO_PROD_CHECK_STRICT=false
SERPRO_RETENTION_PFX_DAYS=2555
SERPRO_RETENTION_TOKEN_DAYS=0
SERPRO_RETENTION_TERMO_DAYS=2555
SERPRO_RETENTION_LEDGER_DAYS=2555
SERPRO_CREDENTIAL_CUTOVER_APPROVALS=2

# SEFAZ / autXML — OFF por padrão
SEFAZ_DISTDFE_ENABLED=false
SEFAZ_MANIFEST_ENABLED=false
SEFAZ_CTE_ENABLED=false
SEFAZ_NFCE_ENABLED=false
SEFAZ_MA_OUTBOUND_ENABLED=false
SEFAZ_AUTXML_DISTDFE_ENABLED=false
SEFAZ_CTE_AUTXML_DISTDFE_ENABLED=false
SEFAZ_SVRS_NFCE_XML_RETRIEVAL_ENABLED=false
SEFAZ_SVRS_NFE55_XML_RETRIEVAL_ENABLED=false

OPS_SCHEDULER_HEARTBEAT_MAX_AGE=180
