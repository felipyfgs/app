# Ambiente da aplicação (não versionar .env real)
APP_ENV=local
APP_PORT=8080
FRONTEND_DEV_PORT=3000
# IP ou hostname usado no browser remoto (HMR WebSocket do Nuxt dev)
# PUBLIC_HOST=192.168.0.10
CHOKIDAR_USEPOLLING=true

# PostgreSQL
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=change-me
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend secrets (também em backend/.env — ver backend/.env.example)
# APP_KEY=base64:...
# VAULT_MASTER_KEY= # 32 bytes em base64, fora de backups comuns
# BACKUP_DISK_ROOT=/var/backups/nfse
# BACKUP_RETENTION_RUNS=7
# BACKUP_SCHEDULE_ENABLED=false
# SERPRO: defaults fail-closed — ver backend/.env.example (SERPRO_KILL_SWITCH, SERPRO_CAPABILITY_*=disabled)
# Nunca coloque Consumer Secret/PFX aqui.
