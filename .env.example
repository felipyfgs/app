# Ambiente da aplicação (não versionar .env real)
APP_ENV=local
APP_PORT=8080
FRONTEND_DEV_PORT=3000
# IP ou hostname usado no browser remoto (HMR WebSocket do Nuxt dev)
# PUBLIC_HOST=192.168.0.10
CHOKIDAR_USEPOLLING=true

# PostgreSQL
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=change-me
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend secrets (também em backend/.env — ver backend/.env.example)
# APP_KEY=base64:...
# VAULT_MASTER_KEY= # 32 bytes em base64, fora de backups comuns
