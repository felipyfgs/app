# Configuração host-only do backup produtivo.
# Copie para /etc/fiscal-hub/backup.env (ou caminho escolhido), chmod 600.
# NÃO monte este arquivo nos containers da aplicação.
# NÃO confunda BACKUP_PACKAGE_KEY com VAULT_MASTER_KEY.

# base64 de 32 bytes (openssl rand -base64 32)
BACKUP_PACKAGE_KEY=substitua-por-32-bytes-aleatorios-em-base64

# Destino local dos pacotes v3
BACKUP_DIR=/var/backups/fiscal-hub

# Retenção local (pacotes) e referências externas
BACKUP_RETENTION_LOCAL=7
BACKUP_RETENTION_OFFSITE_REFS=30

# RPO/RTO (horas) — política inicial do go-live
BACKUP_RPO_HOURS=24
BACKUP_RTO_HOURS=4

# Referência opaca da cópia off-site (sem path/credencial real no git)
OFFSITE_BACKUP_REFERENCE=substitua-por-referencia-opaca-offsite

# Atraso máximo da evidência off-site (horas) antes de marcar como atrasada
OFFSITE_MAX_AGE_HOURS=24
