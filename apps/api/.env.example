APP_NAME="NFS-e ADN"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Bootstrap web do primeiro PLATFORM_ADMIN (produção: usar somente via HTTPS).
# Default OFF; token aleatório com pelo menos 32 caracteres, nunca versionado.
INITIAL_ONBOARDING_ENABLED=false
INITIAL_ONBOARDING_TOKEN=

# TOTP/2FA descontinuado no código (middlewares admin.2fa/platform.2fa são no-op).
# Mantenha false até que o produto reative TOTP real; step-up de senha é usado para mutações sensíveis.
AUTH_TWO_FACTOR_REQUIRED=false

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Manter true fora de testes locais isolados.
SESSION_ENCRYPT=true
SESSION_PATH=/
# Vazio para cookie no host do browser (IP remoto). Evite a string "null".
SESSION_DOMAIN=
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum (same-origin SPA)
# Inclua host:porta usados no browser (ex.: IP:3000 em acesso remoto).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,localhost:3000,127.0.0.1,127.0.0.1:8080,127.0.0.1:3000

# Cofre de objetos (chave mestra fora do banco e de backups comuns)
VAULT_MASTER_KEY=
VAULT_MASTER_KEY_VERSION=1
# JSON opcional de chaves anteriores para leitura durante rewrap: {"1":"base64..."}
VAULT_PREVIOUS_MASTER_KEYS=
VAULT_DISK_ROOT=/var/vault

# Backup da instância (metadados em instance_backup_runs; artefatos fora do webroot)
BACKUP_DISK_ROOT=/var/backups/nfse
BACKUP_RETENTION_RUNS=7
BACKUP_RETENTION_FAILED_RUNS=2
BACKUP_SCHEDULE_ENABLED=false

# ADN
ADN_BASE_URL=https://adn.nfse.gov.br/contribuintes
ADN_ENVIRONMENT=restricted_production
ADN_TIMEOUT_SECONDS=30
ADN_CONNECT_TIMEOUT_SECONDS=10
ADN_MAX_CONCURRENT=4
ADN_RATE_LIMIT_RPS=4
ADN_MAX_PAGES_PER_JOB=20
ADN_DECODE_FAILURE_THRESHOLD=5
ADN_JOB_TIMEOUT_SECONDS=900
ADN_LOCK_TTL_SECONDS=960
ADN_STALE_LEASE_SECONDS=1020

# Consulta pública opcional para auxiliar o cadastro (o cadastro manual permanece disponível)
CNPJ_PUBLIC_LOOKUP_URL=https://publica.cnpj.ws/cnpj
CNPJ_PUBLIC_LOOKUP_TIMEOUT_SECONDS=5
CNPJ_PUBLIC_LOOKUP_CACHE_SECONDS=86400
CNPJ_LOOKUP_CCMEI_ENRICHMENT=false

# API Consulta CNPJ SERPRO (produto separado do Integra Contador; tier QSA). Default off.
CNPJ_LOOKUP_SERPRO_CONSULTA=false
CNPJ_SERPRO_CONSULTA_BASE_URL=https://gateway.apiserpro.serpro.gov.br/consulta-cnpj-df/v2
CNPJ_SERPRO_CONSULTA_QSA_PATH=/qsa
CNPJ_SERPRO_CONSULTA_TOKEN_URL=https://gateway.apiserpro.serpro.gov.br/token
CNPJ_SERPRO_CONSULTA_CONSUMER_KEY=
CNPJ_SERPRO_CONSULTA_CONSUMER_SECRET=
CNPJ_SERPRO_CONSULTA_TIMEOUT_SECONDS=8
CNPJ_SERPRO_CONSULTA_CACHE_SECONDS=86400

# Horizon
HORIZON_PREFIX=nfse_horizon:
HORIZON_JOB_TIMEOUT=900
REDIS_QUEUE_RETRY_AFTER=960

# Captura de saídas MA (NF-e 55 / NFC-e 65) — default off (G0)
# Ver docs/ops/ma-outbound-g0-decision.md
SEFAZ_MA_OUTBOUND_ENABLED=false
SEFAZ_MA_PROTOCOL_QUERY_ENABLED=false
SEFAZ_MA_M2M_RETRIEVAL_ENABLED=false
SEFAZ_MA_MUTATING_PROBE_ENABLED=false
SEFAZ_MA_OUTBOUND_KILL_SWITCH=false
SEFAZ_MA_M2M_STATUS=NO_GO_M2M
SEFAZ_MA_OUTBOUND_QUEUE=capture-outbound-ma
SEFAZ_MA_OUTBOUND_RPS=1
SEFAZ_MA_OUTBOUND_MAX_NUMBERS_PER_RUN=10
SEFAZ_MA_OUTBOUND_RETRY_HOURS=12
SEFAZ_MA_OUTBOUND_MAX_ATTEMPTS=10
SEFAZ_MA_OUTBOUND_SEED_MAX_AGE_DAYS=60

# Canal SVRS — download nfeProc NFC-e 65 por chave + A1 (default off)
# Ver docs/ops/svrs-nfce-enablement-matrix.md
SEFAZ_SVRS_NFCE_XML_RETRIEVAL_ENABLED=false
SEFAZ_SVRS_NFCE_XML_AUTO_QUEUE_ENABLED=false
SEFAZ_SVRS_NFCE_XML_PILOT_ALLOWLIST_ONLY=false
SEFAZ_SVRS_NFCE_XML_KILL_SWITCH=false
SEFAZ_SVRS_NFCE_XML_HOST=dfe-portal.svrs.rs.gov.br
SEFAZ_SVRS_NFCE_XML_QUEUE=capture-outbound-ma
SEFAZ_SVRS_NFCE_XML_TIMEOUT_SECONDS=30
# Budgets defensivos do governador compartilhado (não 5s/30s/20)
SEFAZ_SVRS_NFCE_XML_MAX_KEYS_PER_RUN=1
SEFAZ_SVRS_NFCE_XML_PARSER_VERSION=2

# Governador de egress SVRS (NF-e 55 + NFC-e 65) — preventivo, não limite oficial NFESSL
SVRS_EGRESS_COHORT_ID=default
SVRS_EGRESS_MIN_INTERVAL_GLOBAL=120
SVRS_EGRESS_MIN_INTERVAL_ROOT=900
SVRS_EGRESS_MAX_EXCHANGES_HOUR=10
SVRS_EGRESS_MAX_EXCHANGES_DAY=50
SVRS_EGRESS_MAX_KEYS_ROOT_DAY=6
SVRS_EGRESS_MAX_KEYS_PER_JOB=1

# Canal SVRS NF-e 55 (NFESSL) — default off até smoke formal
SEFAZ_SVRS_NFE55_XML_RETRIEVAL_ENABLED=false
SEFAZ_SVRS_NFE55_XML_AUTO_QUEUE_ENABLED=false
SEFAZ_SVRS_NFE55_XML_PILOT_ALLOWLIST_ONLY=true
SEFAZ_SVRS_NFE55_XML_KILL_SWITCH=false
SEFAZ_SVRS_NFE55_XML_PARSER_VERSION=2

# Canal autXML DistDFe do escritório (default off — gates de piloto)
# Ver docs/ops/autxml-external-distnsu-consumers.md
SEFAZ_AUTXML_DISTDFE_ENABLED=false
SEFAZ_AUTXML_KILL_SWITCH=false
SEFAZ_AUTXML_OFFICE_ALLOWLIST=
SEFAZ_AUTXML_ALLOW_ALL_OFFICES=false
SEFAZ_AUTXML_QUEUE=sync-sefaz-autxml
SEFAZ_AUTXML_MAX_PAGES_PER_JOB=20

# Import em massa XML/ZIP (limites; batch assíncrono default off)
IMPORT_ASYNC_BATCHES_ENABLED=false
IMPORT_MAX_TOP_LEVEL_FILES=50
IMPORT_MAX_FILE_KIB=20480
IMPORT_MAX_REQUEST_COMPRESSED_BYTES=20971520
IMPORT_MAX_XML_ENTRIES=5000
IMPORT_MAX_XML_BYTES=5242880
IMPORT_MAX_BATCH_UNCOMPRESSED_BYTES=262144000
IMPORT_MAX_COMPRESSION_RATIO=100

# ---------------------------------------------------------------------------
# Disponibilidade fiscal: módulos liberados por padrão e restrições pela UI.
# Mutações fiscais permanecem bloqueadas em todos os perfis.
# Perfis: dev (fixture) | trial (real+trial) | production (real+prod). Em Compose,
# o valor efetivo costuma vir do .env da raiz (FISCAL_PROFILE), não só deste arquivo.
# ---------------------------------------------------------------------------
FISCAL_PROFILE=dev
FISCAL_KILL_SWITCH=false

# Reconciliação Pagamento PGDAS-D via PAGTOWEB/PAGAMENTOS71 (bilhetável).
# Exige FISCAL_PROFILE=production + poder e-CAC 00004. Default OFF.
PGDASD_PAGTOWEB_RECONCILIATION_ENABLED=false
# PGDASD_PAGTOWEB_NEGATIVE_TTL_SECONDS=86400
# PGDASD_PAGTOWEB_MAX_DOCUMENTS_PER_BATCH=100
# PGDASD_PAGTOWEB_BACKFILL_MAX_CLIENTS=25
# PGDASD_PAGTOWEB_BACKFILL_MAX_DOCUMENTS=500

# Automacao portal-first MEI (fail-closed; sem egress live por default)
MEI_AUTOMATION_ENABLED=false
MEI_AUTOMATION_KILL_SWITCH=false
MEI_AUTOMATION_LIVE_EGRESS_ENABLED=false
MEI_AUTOMATION_FIXTURE_ENABLED=false
MEI_AUTOMATION_OFFICE_ALLOWLIST=
MEI_AUTOMATION_ALLOW_ALL_OFFICES=false
MEI_AUTOMATION_URL=http://mei:8080
MEI_AUTOMATION_POLL_INTERVAL=10
MEI_AUTOMATION_RESULT_TTL_SECONDS=900
MEI_AUTOMATION_QUEUE=fiscal
MEI_AUTOMATION_ARTIFACT_MAX_BYTES=10485760
MEI_AUTOMATION_HMAC_KEY_ID=laravel
MEI_AUTOMATION_HMAC_SECRET=
MEI_AUTOMATION_PROVIDER_DEFAULT=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DAS_PDF=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DAS_BARCODE=serpro
MEI_AUTOMATION_PROVIDER_PGMEI_DEBT=serpro
MEI_AUTOMATION_PROVIDER_DASN_HISTORY=serpro
MEI_AUTOMATION_CAPTCHA_DRIVER=manual
MEI_AUTOMATION_CAPTCHA_BUDGET_MICROS=0
MEI_AUTOMATION_NOPECHA_ENABLED=false
MEI_AUTOMATION_NOPECHA_API_KEY=
MEI_AUTOMATION_NOPECHA_OPERATION_ALLOWLIST=
MEI_AUTOMATION_NOPECHA_UNIT_COST_MICROS=0
MEI_AUTOMATION_NOPECHA_TIMEOUT_SECONDS=180
MEI_AUTOMATION_NOPECHA_POLL_INTERVAL_SECONDS=1

MAILBOX_MAX_PAGES_PER_SYNC=20

# Contexto privilegiado PLATFORM_ADMIN (seletor global de office). Default OFF
# até aprovação jurídica/segurança de LGPD/sigilo fiscal e plano de rollout.
PLATFORM_PRIVILEGED_CONTEXT=false

# RBAC multi-tenant canônico (platform_admin / tenant_admin / tenant_user + perfis).
# Default OFF — autoridade permanece em OfficeRole até cutover por coorte.
FEATURE_CANONICAL_MULTITENANT_RBAC=false

# Configuração unificada do escritório (perfil + A1 canônico + consentimento). Default OFF.
FEATURE_UNIFIED_OFFICE_CONFIG_ENABLED=false
FEATURE_UNIFIED_OFFICE_CONFIG_OFFICE_ALLOWLIST=
FEATURE_UNIFIED_OFFICE_CONFIG_ALLOW_ALL_OFFICES=false

# Onboarding simplificado de credenciais SERPRO em Produção (console admin).
# Default OFF em produção. Local/dev: ENABLED + ALLOW_ALL (ou OFFICE_ALLOWLIST).
FEATURE_SERPRO_PRODUCTION_ONBOARDING_ENABLED=false
FEATURE_SERPRO_PRODUCTION_ONBOARDING_OFFICE_ALLOWLIST=
FEATURE_SERPRO_PRODUCTION_ONBOARDING_ALLOW_ALL_OFFICES=false

# Agendamento gradual de saídas por prazo (SLA operacional dia 1 — default off)
# Ver docs/ops/outbound-deadline-dependencies.md
OUTBOUND_DEADLINE_SCHEDULING_ENABLED=false
OUTBOUND_DEADLINE_PLANNER_ENABLED=false
OUTBOUND_DEADLINE_DISPATCH_ENABLED=false
OUTBOUND_DEADLINE_SHADOW_MODE=true
OUTBOUND_DEADLINE_RETRY_POLICY=false
OUTBOUND_DEADLINE_TIMEZONE=America/Sao_Paulo
OUTBOUND_DEADLINE_DUE_DAY=1
OUTBOUND_DEADLINE_TARGET_BUFFER_HOURS=48
OUTBOUND_DEADLINE_AUTO_FRACTION=0.60
OUTBOUND_DEADLINE_MAX_TX_PER_KEY=2
OUTBOUND_DEADLINE_NOMINAL_DAILY_EXCHANGES=50

# ---------------------------------------------------------------------------
# Fixtures fiscais demonstrativas (local/testing only — ignoradas em production)
# Ver docs/ops/fiscal-monitoring-demo.md
# ---------------------------------------------------------------------------
FISCAL_DEMO_ENABLED=false
FISCAL_DEMO_OFFICE_SLUG=contador
FISCAL_DEMO_SENTINEL_SLUG=plataforma
DEMO_FISCAL_ANCHOR_AT=2026-06-15T12:00:00-03:00
FISCAL_DEMO_MANIFEST_VERSION=1.0.0

# ---------------------------------------------------------------------------
# SERPRO / Integra Contador — defaults fail-closed para go-live controlado
# Segredos NUNCA aqui: vault + VAULT_MASTER_KEY. Drivers reais default off.
# ---------------------------------------------------------------------------
SERPRO_DEFAULT_ENVIRONMENT=TRIAL
SERPRO_KILL_SWITCH=false
SERPRO_OAUTH_TOKEN_URL=https://autenticacao.sapi.serpro.gov.br/authenticate
# Trial oficial: gateway de demonstração; bearer vem do contrato no banco/cofre.
SERPRO_TRIAL_INTEGRA_BASE_URL=https://gateway.apiserpro.serpro.gov.br/integra-contador-trial/v1
# Produção: gateway contratado, com OAuth mTLS e credenciais no cofre.
SERPRO_PRODUCTION_INTEGRA_BASE_URL=https://gateway.apiserpro.serpro.gov.br/integra-contador/v1
SERPRO_USAGE_SHADOW_MODE=true
SERPRO_USAGE_COMMERCIAL_BLOCKING=false
SERPRO_SMOKE_ENABLED=false
SERPRO_PROD_CHECK_STRICT=false
# Retenção pós-offboarding (dias). Tokens revogados: 0 = purge imediato.
SERPRO_RETENTION_PFX_DAYS=2555
SERPRO_RETENTION_TOKEN_DAYS=0
SERPRO_RETENTION_TERMO_DAYS=2555
SERPRO_RETENTION_POWER_DAYS=2555
SERPRO_RETENTION_EVIDENCE_DAYS=2555
SERPRO_RETENTION_LEDGER_DAYS=2555
# Cutover exige N PLATFORM_ADMIN distintos com TOTP
SERPRO_CREDENTIAL_CUTOVER_APPROVALS=2
