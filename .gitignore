# =============================================================================
# Monorepo hub fiscal — fonte única de ignore na raiz
# backend/ e frontend/ mantêm .gitignore locais (Laravel/Nuxt); este arquivo
# cobre o repositório central e reforça o que nunca deve entrar no git.
# =============================================================================

# --- Referência local (templates clonados; NÃO versionar, sem nested .git) ---
.reference/

# --- Secrets e ambiente ---
.env
.env.*
!.env.example
!.env.prod.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
**/.env
!**/.env.example
!**/.env.prod.example
backend/auth.json
**/auth.json
# Chaves e segredos soltos
**/secrets/
**/*secret*
!**/*.example
!**/*.md

# --- Dependências ---
**/node_modules/
backend/vendor/
# Store local do pnpm (nunca versionar; regenera com install)
**/.pnpm-store/
.pnpm-store/
**/composer.phar
composer.phar

# --- Backend (Laravel) ---
backend/public/build
backend/public/hot
backend/public/storage
backend/public/fonts-manifest.dev.json
backend/storage/*.key
backend/storage/pail
backend/storage/logs/*
!backend/storage/logs/.gitignore
# XML de smoke/fiscal em logs (defesa além de *)
backend/storage/logs/*.xml
backend/storage/app/certs/
backend/storage/app/tmp-manual-nfce/
backend/storage/app/backups/
backend/storage/framework/cache/data/*
!backend/storage/framework/cache/data/.gitignore
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitignore
backend/storage/framework/testing/*
!backend/storage/framework/testing/.gitignore
backend/storage/framework/views/*
!backend/storage/framework/views/.gitignore
# Private disk (volume Docker / artefatos locais)
backend/storage/app/private/*
!backend/storage/app/private/.gitignore
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore
backend/.phpunit.result.cache
backend/.phpunit.cache
backend/_ide_helper.php
backend/_ide_helper_models.php
backend/.phpstorm.meta.php
backend/Homestead.json
backend/Homestead.yaml
backend/.phpactor.json
backend/.php-cs-fixer.cache
backend/.phpstan.result.cache

# --- Frontend (Nuxt) ---
frontend/.nuxt/
frontend/.output/
frontend/.data/
frontend/.nitro/
frontend/.cache/
frontend/dist/
frontend/.fleet/
frontend/.history/
frontend/.eslintcache
frontend/.vite/
frontend/**/*.tsbuildinfo

# --- Docker / runtime local ---
docker-compose.override.yml
docker-compose.*.local.yml
backups/
# dumps acidentais fora de backups/
*.sql
*.sql.gz
*.dump
*.sqlite
*.sqlite3
# Estado ACME (Traefik / Let's Encrypt) — NUNCA versionar
**/acme.json
letsencrypt/
**/letsencrypt/

# --- Vault, dados fiscais e certificados (NUNCA versionar) ---
data/
vault/
.vault/
**/vault-objects/
private_storage/
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer
*.jks
*.p7b
# PDF sensível / termo assinado exportado por engano
**/*termo*.pdf
**/*contrato-serpro*
!docker/**/*.conf
!**/.gitkeep
# Fixtures de teste PEM/PFX ficam em backend/tests/fixtures (git may track if mode allows)

# --- Documentos locais soltos na raiz (contratos, dumps de sessão) ---
/*.pdf
/*.docx
/*.doc
/*.xlsx
/*.xls
/*.csv

# --- Arquivos de backup / pacotes acidentais ---
*.bak
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# --- Temp local ---
tmp/
.tmp/
.cache/
*.tmp
*.temp

# --- Testes / cobertura / caches ---
coverage/
.phpunit.result.cache
.phpunit.cache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE / OS / editores / agentes locais ---
.idea/
.vscode/
.zed/
.nova/
.cursor/
.fleet/
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# --- Ferramentas locais de agente (engines inteiras — só disco local) ---
.grok/
.codex/
.opencode/


# --- Artefatos locais de review/agente e screenshots de sessão ---
.playwright-mcp/
.review-reports/
/image.png
/image copy.png
/pw-*.png
# PNGs acidentais na raiz (screenshots de sessão / debug visual)
/*.png
frontend/pw-clients.mjs
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
# Baselines de regressão visual Playwright — só local (pesados; regenerar com
# PLAYWRIGHT_INCLUDE_VISUAL=1 pnpm test:e2e:visual --update-snapshots)
frontend/tests/e2e/__screenshots__/
# merge/patch leftovers
*.orig
*.rej
